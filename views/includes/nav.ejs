<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg " style="background-color: black;color: white;">
  <div class="container-fluid" >
    <a class="navbar-brand" href="#" style="color: white;">MyBlogApp</a>
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav"
      aria-controls="navbarNav"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link active" aria-current="page" href="http://localhost:8080/blog" style="color: white;">All Blogs</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="http://localhost:8080/blog/new" style="color: white;">Create</a>
        </li>
      </ul>

      <!-- Search form aligned to the right -->
      <form class="d-flex ms-auto" role="search" action="/blog/search" method="GET">
        <input
          class="form-control me-2"
          type="search"
          name="q"
          placeholder="Search blogs"
          aria-label="Search"
        />
        <button class="btn btn-outline-success" type="submit">Search</button>
      </form>
    </div>
  </div>
</nav>

</body>
</html>